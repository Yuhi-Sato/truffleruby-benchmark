# Ruby 4.0.2 with YJIT enabled.
#
# YJIT ships compiled into the official ruby:4.0.2 image; we just opt into it
# at runtime via --yjit (RUBY_YJIT_ENABLE=1 also works).
FROM ruby:4.0.2-slim

WORKDIR /bench
COPY benchmarks /bench/benchmarks

ENV RUBYOPT="--yjit"

# Sanity: print version + YJIT status when image starts (overridden by driver).
CMD ["ruby", "--yjit", "-e", "puts RUBY_DESCRIPTION; require 'rbconfig'; p RubyVM::YJIT.enabled? if defined?(RubyVM::YJIT)"]
